{
  "name": "bounded-dllm-agent-lab",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Open-source research lab for bounded-context dLLM agents, synthetic context enrichment, and shared semantic workspaces.",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "test:smoke": "node dist/tests/smoke/contracts.js",
    "eval:demo": "node dist/apps/cli/src/index.js",
    "reports:compare": "node dist/apps/cli/src/compare-reports.js",
    "worker:dry-run": "node dist/apps/cli/src/worker-dry-run.js",
    "worker:smoke": "node dist/apps/cli/src/worker-smoke.js",
    "worker:dream": "python3 apps/dllm-worker/dream_worker.py",
    "clean": "rm -rf dist"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.6.3"
  }
}
