{
  "name": "bounded-dllm-agent-lab",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Open-source research lab for bounded-context dLLM agents, synthetic context enrichment, and shared semantic workspaces.",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "test:smoke": "node dist/tests/smoke/contracts.js",
    "eval:demo": "node dist/apps/cli/src/index.js",
    "reports:compare": "node dist/apps/cli/src/compare-reports.js",
    "reports:llm-context": "node dist/apps/cli/src/llm-context-comparison.js",
    "reports:research-figures": "node dist/apps/cli/src/research-figures.js",
    "oss:prepare": "node dist/apps/cli/src/prepare-oss-repo.js",
    "code:benchmark": "node dist/apps/cli/src/code-patch-benchmark.js",
    "code:model-benchmark": "node dist/apps/cli/src/code-model-patch-benchmark.js",
    "code:model-rag-benchmark": "CODE_CONTEXT_STRATEGY=rag node dist/apps/cli/src/code-model-patch-benchmark.js",
    "code:model-expanded-benchmark": "CODE_CONTEXT_STRATEGY=expanded node dist/apps/cli/src/code-model-patch-benchmark.js",
    "code:model-synthetic-benchmark": "CODE_CONTEXT_STRATEGY=synthetic node dist/apps/cli/src/code-model-patch-benchmark.js",
    "code:dllm-benchmark": "node dist/apps/cli/src/code-dllm-patch-benchmark.js",
    "code:failure-taxonomy": "node dist/apps/cli/src/code-failure-taxonomy.js",
    "ablation:run": "node dist/apps/cli/src/ablation-run.js",
    "hard:benchmark": "node dist/apps/cli/src/ablation-run.js --suite hard --modes bounded_refinement",
    "hard:ablation": "node dist/apps/cli/src/ablation-run.js --suite hard",
    "remask:benchmark": "node dist/apps/cli/src/remask-benchmark.js",
    "worker:dry-run": "node dist/apps/cli/src/worker-dry-run.js",
    "worker:mini-benchmark": "node dist/apps/cli/src/worker-mini-benchmark.js",
    "worker:full-benchmark": "node dist/apps/cli/src/worker-full-benchmark.js",
    "worker:hard-benchmark": "node dist/apps/cli/src/worker-hard-benchmark.js",
    "worker:llm-hard-benchmark": "node dist/apps/cli/src/worker-llm-context-benchmark.js",
    "worker:llm-rag-hard-benchmark": "LLM_CONTEXT_STRATEGY=rag node dist/apps/cli/src/worker-llm-context-benchmark.js",
    "worker:llm-expanded-hard-benchmark": "LLM_CONTEXT_STRATEGY=expanded node dist/apps/cli/src/worker-llm-context-benchmark.js",
    "worker:llm-synthetic-hard-benchmark": "LLM_CONTEXT_STRATEGY=synthetic node dist/apps/cli/src/worker-llm-context-benchmark.js",
    "worker:smoke": "node dist/apps/cli/src/worker-smoke.js",
    "worker:dream": "python3 apps/dllm-worker/dream_worker.py",
    "worker:llm-openai": "node dist/apps/llm-worker/openai_compatible_worker.js",
    "oracle:audit": "node dist/apps/cli/src/oracle-audit.js",
    "clean": "rm -rf dist"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.6.3"
  }
}
